---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="min-h-screen flex items-center">
    <div class="container-kt py-16">
      <div class="surface rounded-2xl p-8 sm:p-10 max-w-2xl mx-auto text-center">
        <h1
          class="text-4xl sm:text-5xl font-bold
          bg-gradient-to-r from-[color:var(--text)] to-[color:var(--muted)]
          bg-clip-text text-transparent"
        >
          404 — Página no encontrada
        </h1>

        <div
          class="h-px w-72 sm:w-80 mx-auto my-6 rounded
          bg-gradient-to-r from-[color:var(--border)] to-[color:var(--brand)]"
        ></div>

        <p class="text-muted text-base sm:text-lg">
          La página que estás buscando no existe o fue movida.
        </p>

        <div class="mt-8 flex justify-center gap-3 flex-wrap">
          <a href="/" class="btn-brand inline-flex items-center gap-2">
            Volver al inicio
            <span aria-hidden="true" class="transition group-hover:translate-x-1">→</span>
          </a>

          <a href="/#contacto" class="btn-surface">
            Contáctanos
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
