---

---

<section id="contacto" class="bg-[color:var(--bg)]">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight text-[color:var(--text)] sm:text-4xl">
        Contacto
      </h2>
      <p class="mt-2 text-sm text-[color:var(--muted)] sm:text-base">
        Agenda tu cita, resuelve dudas o encuentra cómo llegar.
      </p>
    </header>

    <!-- Layout -->
    <div class="mt-10 grid gap-6 lg:grid-cols-2 lg:items-stretch">
      <!-- LEFT -->
      <div class="grid gap-6 lg:grid-rows-[auto_1fr]">
        <!-- Redes (ARRIBA) -->
        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--panel)] p-6 shadow-sm">
          <div class="flex items-center gap-3">
            <span
              class="grid size-10 place-items-center rounded-xl bg-[color:var(--brand)]/15 text-[color:var(--brand)]"
              aria-hidden="true"
            >
              <!-- icon -->
              <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M4 7a3 3 0 013-3h10a3 3 0 013 3v10a3 3 0 01-3 3H7a3 3 0 01-3-3V7z"/>
              </svg>
            </span>

            <div>
              <h3 class="text-base font-semibold text-[color:var(--text)]">Síguenos</h3>
              <p class="text-sm text-[color:var(--muted)]">
                Novedades, trabajos y promociones en redes.
              </p>
            </div>
          </div>

          <!-- Botones redes: responsivo y sin que el texto se salga -->
          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <!-- IG -->
            <a
              href="https://www.instagram.com/karitianamiradasperfectas"
              target="_blank"
              rel="noreferrer"
              class="group flex items-center gap-3 rounded-xl border border-[color:var(--border)]
                     bg-[color:var(--bg)] px-4 py-3 shadow-sm transition
                     hover:border-[color:var(--brand)] hover:bg-[color:var(--brand)]/10"
            >
              <span class="grid size-10 place-items-center rounded-lg bg-[color:var(--brand)]/15 text-[color:var(--brand)]">
                <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M7.75 2C4.574 2 2 4.574 2 7.75v8.5C2 19.426 4.574 22 7.75 22h8.5C19.426 22 22 19.426 22 16.25v-8.5C22 4.574 19.426 2 16.25 2h-8.5zm0 2h8.5A3.75 3.75 0 0120 7.75v8.5A3.75 3.75 0 0116.25 20h-8.5A3.75 3.75 0 014 16.25v-8.5A3.75 3.75 0 017.75 4zm4.25 2.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zm0 2a3.5 3.5 0 110 7 3.5 3.5 0 010-7zm4.75-.75a1 1 0 100 2 1 1 0 000-2z"/>
                </svg>
              </span>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-[color:var(--text)]">Instagram</p>
                <p class="text-xs text-[color:var(--muted)] truncate">@karitianamiradasperfectas</p>
              </div>
            </a>

            <!-- FB -->
            <a
              href="https://www.facebook.com/karitianaentrecyp"
              target="_blank"
              rel="noreferrer"
              class="group flex items-center gap-3 rounded-xl border border-[color:var(--border)]
                     bg-[color:var(--bg)] px-4 py-3 shadow-sm transition
                     hover:border-[color:var(--brand)] hover:bg-[color:var(--brand)]/10"
            >
              <span class="grid size-10 place-items-center rounded-lg bg-[color:var(--brand)]/15 text-[color:var(--brand)]">
                <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M22 12a10 10 0 10-11.563 9.875v-6.987H7.898V12h2.539V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.888h-2.33v6.987A10 10 0 0022 12z"/>
                </svg>
              </span>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-[color:var(--text)]">Facebook</p>
                <p class="text-xs text-[color:var(--muted)] truncate">karitianaentrecyp</p>
              </div>
            </a>

            <!-- TikTok (pon link real) -->
            <a
              href="https://www.tiktok.com/@karitianamiradasperfecta?_r=1&_t=ZN-94HcBFh8B6J"
              target="_blank"
              rel="noreferrer"
              class="group flex items-center gap-3 rounded-xl border border-[color:var(--border)]
                     bg-[color:var(--bg)] px-4 py-3 shadow-sm transition
                     hover:border-[color:var(--brand)] hover:bg-[color:var(--brand)]/10"
            >
              <span class="grid size-10 place-items-center rounded-lg bg-[color:var(--brand)]/15 text-[color:var(--brand)]">
                <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M16 3c.4 2.7 2 4.3 4.5 4.5V11c-1.6 0-3-.5-4.2-1.4V16c0 3.4-2.6 6-6 6s-6-2.6-6-6 2.6-6 6-6c.3 0 .7 0 1 .1v3.6c-.3-.2-.7-.3-1-.3-1.4 0-2.5 1.1-2.5 2.5S9 18.5 10.4 18.5c1.5 0 2.6-1.1 2.6-2.8V3h3z"/>
                </svg>
              </span>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-[color:var(--text)]">TikTok</p>
                <p class="text-xs text-[color:var(--muted)] truncate">Tu usuario</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Ubicación (ABAJO) con mapa -->
        <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--panel)] p-6 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div class="flex items-center gap-3">
              <span class="grid size-10 place-items-center rounded-xl bg-[color:var(--brand)]/15 text-[color:var(--brand)]">
                <!-- pin -->
                <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2a7 7 0 00-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 00-7-7zm0 9.5A2.5 2.5 0 1112 6a2.5 2.5 0 010 5.5z"/>
                </svg>
              </span>
              <div>
                <h3 class="text-base font-semibold text-[color:var(--text)]">Ubicación</h3>
                <p class="text-sm text-[color:var(--muted)]">Girardot, Cundinamarca</p>
              </div>
            </div>

            <span class="rounded-full border border-[color:var(--border)] bg-[color:var(--bg)] px-3 py-1 text-xs text-[color:var(--muted)]">
              Atención con cita previa
            </span>
          </div>

          <div class="mt-4 space-y-2 text-sm">
            <p class="text-[color:var(--text)]">
              <span class="text-[color:var(--muted)]">Dirección:</span>
              Calle 19 #12-87, Girardot, Colombia, 252432
            </p>
            <p class="text-[color:var(--text)]">
              <span class="text-[color:var(--muted)]">Tel:</span>
              +57 313 218 8779
            </p>
          </div>

          <!-- Mapa bonito -->
          <div class="mt-4 overflow-hidden rounded-2xl border border-[color:var(--border)] bg-[color:var(--bg)]">
            <div class="relative aspect-[16/9] w-full">
              <!-- Pega aquí tu iframe -->
              <iframe
                class="absolute inset-0 h-full w-full"
                src="https://www.google.com/maps/embed?pb=TU_EMBED_AQUI"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>

            <!-- CTA debajo del mapa -->
            <div class="flex flex-col gap-3 border-t border-[color:var(--border)] p-4 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-sm text-[color:var(--muted)]">
                ¿Quieres llegar fácil? Ábrelo en Google Maps.
              </p>

              <a
                href="https://www.google.com/maps"
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center justify-center rounded-xl bg-[color:var(--brand)] px-4 py-2 text-sm font-semibold text-black
                       shadow-sm transition hover:brightness-110"
              >
                Ver cómo llegar
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT (form) -->
      <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--panel)] p-6 shadow-sm">
        <div class="flex items-center gap-3">
          <span class="grid size-10 place-items-center rounded-xl bg-[color:var(--brand)]/15 text-[color:var(--brand)]">
            <!-- msg -->
            <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M4 4h16v12H7l-3 3V4z"/>
            </svg>
          </span>
          <div>
            <h3 class="text-base font-semibold text-[color:var(--text)]">Envíanos un mensaje</h3>
            <p class="text-sm text-[color:var(--muted)]">Te respondemos lo más pronto posible.</p>
          </div>
        </div>

        <form class="mt-6 space-y-4">
          <div>
            <label class="text-sm text-[color:var(--muted)]">Nombre</label>
            <input
              type="text"
              placeholder="Tu nombre"
              class="mt-2 w-full rounded-xl border border-[color:var(--border)] bg-[color:var(--bg)] px-4 py-3 text-sm text-[color:var(--text)]
                     outline-none transition focus:border-[color:var(--brand)]"
            />
          </div>

          <div>
            <label class="text-sm text-[color:var(--muted)]">Correo</label>
            <input
              type="email"
              placeholder="tucorreo@ejemplo.com"
              class="mt-2 w-full rounded-xl border border-[color:var(--border)] bg-[color:var(--bg)] px-4 py-3 text-sm text-[color:var(--text)]
                     outline-none transition focus:border-[color:var(--brand)]"
            />
          </div>

          <div>
            <label class="text-sm text-[color:var(--muted)]">Mensaje</label>
            <textarea
              rows="6"
              placeholder="Cuéntanos qué necesitas..."
              class="mt-2 w-full resize-none rounded-xl border border-[color:var(--border)] bg-[color:var(--bg)] px-4 py-3 text-sm text-[color:var(--text)]
                     outline-none transition focus:border-[color:var(--brand)]"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full rounded-xl bg-[color:var(--brand)] px-4 py-3 text-sm font-semibold text-black shadow-sm transition hover:brightness-110"
          >
            Enviar mensaje
          </button>

          <p class="text-xs text-[color:var(--muted)]">
            Al enviar, aceptas que te contactemos para responder tu solicitud.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>