---
import masterclass_img from "../assets/masterclass.jpg";
---

<section id="masterclass" class="bg-white">
  <div
    class="mx-auto w-screen max-w-7xl px-4 py-16 sm:px-6 sm:py-24 md:grid md:grid-cols-2 md:items-center md:gap-10 lg:px-8 lg:py-28"
  >
    <!-- Texto -->
    <div class="max-w-prose text-left">
      <h2
        class="mt-5 text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl"
      >
        MasterClass
        <span class="block text-amber-600">Cejas & Pestañas</span>
      </h2>
      <p
        class="mt-5 inline-flex items-center gap-2 rounded-full border border-amber-200 bg-amber-50 px-4 py-1 text-sm font-medium text-amber-800"
      >
        Girardot, Cundinamarca
        <span class="h-1 w-1 rounded-full bg-amber-400"></span>
        Incluye kit profesional
      </p>

      <p class="mt-4 text-base text-pretty text-gray-700 sm:text-lg/relaxed">
        Aprende de la mano de la profesional <span
          class="font-semibold text-gray-900">Karen Barragán</span
        > en
        <span class="font-semibold text-gray-900">Karitiana</span>. Formación
        práctica, cupos limitados y acompañamiento durante la clase.
      </p>

      <ul class="mt-6 space-y-3 text-gray-800">
        <li class="flex gap-3">
          <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-amber-500"></span>
          <span
            ><span class="font-semibold">Diseño de cejas</span> (técnica y simetría)</span
          >
        </li>
        <li class="flex gap-3">
          <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-amber-500"></span>
          <span><span class="font-semibold">Depilación hindú</span> (hilo)</span
          >
        </li>
        <li class="flex gap-3">
          <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-amber-500"></span>
          <span
            ><span class="font-semibold">Sombreado semipermanente</span></span
          >
        </li>
      </ul>

      <div class="mt-6 rounded-xl border border-gray-100 bg-gray-50 p-4">
        <p class="font-semibold text-red-600 text-2xl">¡Cupos limitados!</p>
        <p class="mt-1 text-gray-700">
          Más info:
          <a
            href="tel:+573132188779"
            class="font-semibold text-amber-700 hover:text-amber-800"
          >
            +57 313 218 8779
          </a>
        </p>
        <!-- k -->
        <div
          class="mt-2 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4"
        >
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/karitianamiradasperfectas"
            target="_blank"
            rel="noopener noreferrer"
            class="flex w-full items-center gap-2 text-[color:var(--muted)] transition hover:text-[color:var(--brand)] sm:w-auto"
          >
            <!-- icon instagram -->
            <svg
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M7.75 2C4.574 2 2 4.574 2 7.75v8.5C2 19.426 4.574 22 7.75 22h8.5C19.426 22 22 19.426 22 16.25v-8.5C22 4.574 19.426 2 16.25 2h-8.5zm0 2h8.5A3.75 3.75 0 0120 7.75v8.5A3.75 3.75 0 0116.25 20h-8.5A3.75 3.75 0 014 16.25v-8.5A3.75 3.75 0 017.75 4zm4.25 2.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zm0 2a3.5 3.5 0 110 7 3.5 3.5 0 010-7zm4.75-.75a1 1 0 100 2 1 1 0 000-2z"
              ></path>
            </svg>

            <span class="min-w-0 font-medium break-words">
              @karitianamiradasperfectas
            </span>
          </a>

          <!-- Facebook -->
          <a
            href="https://www.facebook.com/karitianaentrecyp"
            target="_blank"
            rel="noopener noreferrer"
            class="flex w-full items-center gap-2 text-[color:var(--muted)] transition hover:text-[color:var(--brand)] sm:w-auto"
          >
            <!-- icon facebook -->
            <svg
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M22 12a10 10 0 10-11.563 9.875v-6.987H7.898V12h2.539V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.888h-2.33v6.987A10 10 0 0022 12z"
              ></path>
            </svg>

            <span class="min-w-0 font-medium break-words">
              Karitiana Entre Cejas y Pestañas
            </span>
          </a>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          class="inline-flex items-center justify-center rounded-lg bg-amber-600 px-5 py-3 font-semibold text-white shadow-sm transition hover:bg-amber-700"
          href="https://wa.me/573132188779"
          target="_blank"
          rel="noreferrer"
        >
          Escribir por WhatsApp
        </a>

        <a
          class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-5 py-3 font-semibold text-gray-800 shadow-sm transition hover:bg-gray-50"
          href="tel:+573132188779"
        >
          Llamar
        </a>
      </div>
    </div>

    <!-- Imagen -->
    <div class="mt-10 md:mt-0">
      <figure
        class="relative mx-auto max-w-md overflow-hidden rounded-2xl border border-gray-100 shadow-lg"
      >
        <img
          src={masterclass_img.src}
          alt="MasterClass Karitiana - Entre Cejas y Pestañas (incluye kit profesional)"
          class="h-auto w-full object-cover"
          loading="lazy"
        />
      </figure>
    </div>
  </div>
</section>
