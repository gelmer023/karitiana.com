---
import micropigmentacion from "../assets/micropigmentacion.jpg";
import depihindu from "../assets/depihindu.jpg";
import laminadoCejas from "../assets/laminado_cejas.jpg";
import liftingPestanas from "../assets/lifting_pestañas.jpg";
import sombreado from "../assets/sombreado.jpg";

const PLACEHOLDER =
  "https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?auto=format&fit=crop&w=1200&q=80";

const servicios = [
  { icon:"🖋️", titulo:"Micropigmentación efecto sombreado / polvo", precio:250000, imagen: micropigmentacion.src },
  { icon:"🧤", titulo:"Depilación hindú y diseño", precio:20000, imagen: depihindu.src },
  { icon:"🖌️", titulo:"Sombreado semipermanente", precio:32000, imagen: sombreado.src },
  { icon:"🪄", titulo:"Laminado de cejas (diseño + depilación hindú + sombreado)", precio:60000, imagen: laminadoCejas.src },
  { icon:"🪞", titulo:"Laminado de cejas (diseño + depilación hindú)", precio:45000, imagen: laminadoCejas.src },
  { icon:"📍", titulo:"Depilación hindú de bozo", precio:12000, imagen: PLACEHOLDER },
  { icon:"🔎", titulo:"Depilación hindú de axila", precio:24000, imagen: PLACEHOLDER },
  { icon:"🖋️", titulo:"Depilación hindú facial", precio:30000, imagen: depihindu.src },
  { icon:"👁️", titulo:"Pestañas punto a punto", precio:35000, precioHasta:45000, imagen: liftingPestanas.src },
  { icon:"🔎", titulo:"Lifting de pestañas", precio:70000, imagen: liftingPestanas.src },
];

const money = (n) =>
  new Intl.NumberFormat("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 }).format(n);

const visibles = servicios.slice(0, 6);
const extra = servicios.slice(6);
---

<section id="servicios" class="bg-[color:var(--bg)]">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-16 lg:px-8">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold text-[color:var(--text)] sm:text-4xl">Servicios</h2>
      <p class="mt-3 text-[color:var(--muted)]">
        Descubre los tratamientos ideales para resaltar tu mirada.
      </p>
    </div>

    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {visibles.map((s) => (
        <article class="relative overflow-hidden rounded-2xl border border-[color:var(--border)] bg-[color:var(--panel)] shadow-sm transition hover:shadow-lg">
          <img src={s.imagen} alt={s.titulo} class="w-full aspect-[4/3] object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent"></div>

          <div class="absolute inset-x-0 bottom-0 p-5 text-white">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-lg font-semibold leading-snug">
                <span class="mr-2">{s.icon}</span>{s.titulo}
              </h3>

              <span
                class="shrink-0 rounded-full px-3 py-1 text-xs font-medium"
                style="background: color-mix(in srgb, var(--brand) 85%, black 15%);"
              >
                {s.precioHasta ? `Desde ${money(s.precio)}` : money(s.precio)}
              </span>
            </div>

            {s.precioHasta && (
              <p class="mt-2 text-sm text-white/85">
                Rango: {money(s.precio)} – {money(s.precioHasta)}
              </p>
            )}
          </div>
        </article>
      ))}
    </div>

    {extra.length > 0 && (
      <details class="mt-8 group">
        <summary
          class="cursor-pointer list-none inline-flex items-center gap-2 rounded-xl px-5 py-2.5 text-sm font-semibold shadow-sm transition hover:opacity-90"
          style="background: var(--surface-mix); border: 1px solid var(--border); color: var(--text);"
        >
          <span class="group-open:hidden">Ver más servicios</span>
          <span class="hidden group-open:inline">Ver menos</span>
          <span class="transition group-open:rotate-180">▾</span>
        </summary>

        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {extra.map((s) => (
            <article class="relative overflow-hidden rounded-2xl border border-[color:var(--border)] bg-[color:var(--panel)] shadow-sm transition hover:shadow-lg">
              <img src={s.imagen} alt={s.titulo} class="w-full aspect-[4/3] object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent"></div>

              <div class="absolute inset-x-0 bottom-0 p-5 text-white">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-lg font-semibold leading-snug">
                    <span class="mr-2">{s.icon}</span>{s.titulo}
                  </h3>

                  <span
                    class="shrink-0 rounded-full px-3 py-1 text-xs font-medium"
                    style="background: color-mix(in srgb, var(--brand) 85%, black 15%);"
                  >
                    {s.precioHasta ? `Desde ${money(s.precio)}` : money(s.precio)}
                  </span>
                </div>

                {s.precioHasta && (
                  <p class="mt-2 text-sm text-white/85">
                    Rango: {money(s.precio)} – {money(s.precioHasta)}
                  </p>
                )}
              </div>
            </article>
          ))}
        </div>
      </details>
    )}
  </div>
</section>