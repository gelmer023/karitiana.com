---

---

<footer class="relative bg-[color:var(--bg)] text-[color:var(--text)]">
  <!-- línea superior suave -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-[color:var(--border)] to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-3">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3">
          <!-- Usa tu logo real aquí si quieres -->
          <div class="grid size-10 place-items-center rounded-xl border border-[color:var(--border)] bg-[color:var(--panel)] shadow-sm">
            <span class="font-semibold text-[color:var(--brand)]">KT</span>
          </div>

          <div>
            <p class="text-base font-semibold tracking-wide">KARITIANA</p>
            <p class="text-xs text-[color:var(--muted)]">Entre Cejas &amp; Pestañas</p>
          </div>
        </div>

        <p class="mt-4 max-w-sm text-sm leading-relaxed text-[color:var(--muted)]">
          Belleza y precisión para realzar tu mirada. Agenda tu cita y conoce nuestros servicios.
        </p>

        <!-- Redes (responsivo) -->
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="https://www.instagram.com/karitianamiradasperfectas"
            target="_blank"
            rel="noreferrer"
            class="inline-flex w-3/4 items-center gap-2 rounded-xl border border-[color:var(--border)] bg-[color:var(--panel)] px-4 py-2 text-sm text-[color:var(--text)] shadow-sm transition hover:border-[color:var(--brand)] hover:text-[color:var(--brand)]"
          >
            <!-- Instagram icon -->
            <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M7.75 2C4.574 2 2 4.574 2 7.75v8.5C2 19.426 4.574 22 7.75 22h8.5C19.426 22 22 19.426 22 16.25v-8.5C22 4.574 19.426 2 16.25 2h-8.5zm0 2h8.5A3.75 3.75 0 0120 7.75v8.5A3.75 3.75 0 0116.25 20h-8.5A3.75 3.75 0 014 16.25v-8.5A3.75 3.75 0 017.75 4zm4.25 2.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zm0 2a3.5 3.5 0 110 7 3.5 3.5 0 010-7zm4.75-.75a1 1 0 100 2 1 1 0 000-2z"
              />
            </svg>
            <span class="max-w-max truncate">@karitianamiradasperfectas</span>
          </a>

          <a
            href="https://www.facebook.com/karitianaentrecyp"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-[color:var(--border)] bg-[color:var(--panel)] px-4 py-2 text-sm text-[color:var(--text)] shadow-sm transition hover:border-[color:var(--brand)] hover:text-[color:var(--brand)]"
          >
            <!-- Facebook icon -->
            <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M22 12a10 10 0 10-11.563 9.875v-6.987H7.898V12h2.539V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.888h-2.33v6.987A10 10 0 0022 12z"
              />
            </svg>
            <span class="max-w-[22ch] truncate">karitianaentrecyp</span>
          </a>

          <!-- TikTok (pon tu link real cuando lo tengas) -->
          <a
            href="https://www.tiktok.com/@karitianamiradasperfecta?_r=1&_t=ZN-94HcBFh8B6J"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-[color:var(--border)] bg-[color:var(--panel)] px-4 py-2 text-sm text-[color:var(--text)] shadow-sm transition hover:border-[color:var(--brand)] hover:text-[color:var(--brand)]"
          >
            <!-- TikTok icon (simple) -->
            <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M16 3c.4 2.7 2 4.3 4.5 4.5V11c-1.6 0-3-.5-4.2-1.4V16c0 3.4-2.6 6-6 6s-6-2.6-6-6 2.6-6 6-6c.3 0 .7 0 1 .1v3.6c-.3-.2-.7-.3-1-.3-1.4 0-2.5 1.1-2.5 2.5S9 18.5 10.4 18.5c1.5 0 2.6-1.1 2.6-2.8V3h3z"
              />
            </svg>
            <span class="max-w-[18ch] truncate">TikTok</span>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="lg:col-span-2">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <p class="text-sm font-semibold text-[color:var(--text)]">Servicios</p>
            <ul class="mt-4 space-y-3 text-sm">
              <li><a href="#servicios" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Cejas</a></li>
              <li><a href="#servicios" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Pestañas</a></li>
              <li><a href="#masterclass" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Masterclass</a></li>
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-[color:var(--text)]">Karitiana</p>
            <ul class="mt-4 space-y-3 text-sm">
              <li><a href="#acerca" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Acerca de</a></li>
              <li><a href="#contacto" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Contacto</a></li>
              <li><a href="#blog" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Blog</a></li>
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-[color:var(--text)]">Ayuda</p>
            <ul class="mt-4 space-y-3 text-sm">
              <li><a href="#contacto" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Agenda tu cita</a></li>
              <li><a href="#contacto" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Preguntas</a></li>
            </ul>
          </div>

          <div>
            <p class="text-sm font-semibold text-[color:var(--text)]">Legal</p>
            <ul class="mt-4 space-y-3 text-sm">
              <li><a href="#" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Términos</a></li>
              <li><a href="#" class="text-[color:var(--muted)] hover:text-[color:var(--brand)] transition">Privacidad</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- bottom bar -->
    <div class="mt-12 flex flex-col gap-3 border-t border-[color:var(--border)] pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-[color:var(--muted)]">
        © 2022. Company Name. All rights reserved.
      </p>

      <p class="text-xs text-[color:var(--muted)]">
        Hecho con <span class="text-[color:var(--brand)]">♥</span> en Girardot
      </p>
    </div>
  </div>
</footer>